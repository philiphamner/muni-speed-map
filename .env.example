# Example environment variables for collectors
# Copy to .env and fill with real values

# ===========================================
# REQUIRED: Supabase connection
# ===========================================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# REQUIRED: Transit API Keys (per city)
# ===========================================

# San Francisco / VTA (511.org API)
API_511_KEY=your_511_api_key

# Seattle (OneBusAway API)
OBA_API_KEY=your_oba_api_key

# Phoenix (Valley Metro / Mecatran API)
PHOENIX_API_KEY=your_phoenix_api_key

# San Diego (MTS API)
MTS_API_KEY=your_mts_api_key

# Boston (MBTA API)
MBTA_API_KEY=your_mbta_api_key

# Portland (TriMet API)
TRIMET_APP_ID=your_trimet_app_id

# Baltimore (Swiftly API)
SWIFTLY_KEY=your_swiftly_api_key

# ===========================================
# OPTIONAL: Frontend (Vite)
# ===========================================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# OPTIONAL: Polling configuration
# ===========================================
POLL_INTERVAL_MS=90000
